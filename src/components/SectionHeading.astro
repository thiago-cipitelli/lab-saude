---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, title, align = 'left', class: className } = Astro.props;
---

<div
  class:list={[align === 'center' && 'text-center', className]}
  data-reveal
>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-2 text-3xl text-ink sm:text-4xl md:text-[2.75rem]">
    {title}
  </h2>
  {
    Astro.slots.has('default') && (
      <div
        class:list={[
          'mt-4 max-w-2xl text-lg text-ink-soft',
          align === 'center' && 'mx-auto',
        ]}
      >
        <slot />
      </div>
    )
  }
</div>
