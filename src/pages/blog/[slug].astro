---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { SITE, formatDate } from '../../lib/site';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  const n = posts.length;

  return posts.map((post, i) => {
    // Vizinhos por data (lista em ordem decrescente), com wrap nas pontas
    const anterior = posts[(i + 1) % n]; // mais antigo
    const proximo = posts[(i - 1 + n) % n]; // mais recente
    const relacionados = [anterior, proximo].filter(
      (p, idx, arr) =>
        p.id !== post.id && arr.findIndex((x) => x.id === p.id) === idx,
    );
    return { params: { slug: post.id }, props: { post, relacionados } };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  relacionados: CollectionEntry<'blog'>[];
}

const { post, relacionados } = Astro.props;
const { title, date, excerpt, content, cover, coverAlt } = post.data;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  datePublished: date.toISOString(),
  description: excerpt,
  ...(cover ? { image: cover } : {}),
  mainEntityOfPage: new URL(`/blog/${post.id}/`, Astro.site ?? Astro.url).href,
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
  },
};
---

<BaseLayout
  title={title}
  description={excerpt}
  image={cover ?? undefined}
  type="article"
  publishedTime={date.toISOString()}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="container-site pt-14 pb-20 md:pt-20 md:pb-28">
    <!-- Cabeçalho editorial centrado -->
    <header class="mx-auto max-w-3xl text-center" data-reveal>
      <a
        href="/blog/"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-ink-soft transition-colors hover:text-brand"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M12 7H2m0 0 4-4M2 7l4 4"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Blog
      </a>

      <time
        datetime={date.toISOString()}
        class="mt-7 block text-xs font-bold tracking-[0.2em] text-brand uppercase"
      >
        {formatDate(date)}
      </time>

      <h1 class="mt-4 text-3xl text-ink sm:text-4xl md:text-[3.25rem]">
        {title}
      </h1>

      {
        excerpt && (
          <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft md:text-xl">
            {excerpt}
          </p>
        )
      }
    </header>

    <!-- Capa -->
    {
      cover && (
        <figure
          class="mx-auto mt-12 max-w-4xl md:mt-14"
          data-reveal
          style="--reveal-delay: 120ms"
        >
          <Image
            src={cover}
            alt={coverAlt || title}
            width={1360}
            height={765}
            class="w-full rounded-2xl object-cover shadow-card"
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      )
    }

    <!-- Corpo do post -->
    <div class="prose mx-auto mt-12 md:mt-16" set:html={content} />
  </article>

  <!-- Continue lendo -->
  {
    relacionados.length > 0 && (
      <aside class="border-t border-line" aria-label="Continue lendo">
        <div class="container-site py-20 md:py-24">
          <SectionHeading eyebrow="Mais do blog" title="Continue lendo">
            Outras leituras para seguir cuidando da sua saúde.
          </SectionHeading>
          <div class="mt-10 grid gap-7 sm:grid-cols-2 md:gap-8">
            {relacionados.map((rel, i) => (
              <BlogCard post={rel} index={i} />
            ))}
          </div>
        </div>
      </aside>
    )
  }
</BaseLayout>
