---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Stamp from '../../components/Stamp.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const [destaque, ...demais] = posts;
---

<BaseLayout
  title="Blog"
  description="Dicas de saúde e bem-estar do Laboratório Saúde: artigos e novidades para o cuidado do dia a dia."
>
  <section class="container-site pt-16 pb-10 md:pt-24 md:pb-14">
    <div class="relative" data-reveal>
      <div class="max-w-3xl">
        <p class="eyebrow">Blog</p>
        <h1 class="mt-3 text-4xl text-ink sm:text-5xl md:text-6xl">
          Dicas de <em class="italic text-brand">saúde</em> e bem-estar
        </h1>
        <p class="mt-5 max-w-2xl text-lg text-ink-soft">
          Artigos e novidades do Laboratório Saúde para acompanhar o cuidado de
          todo dia — leia com calma, como quem toma um chimarrão.
        </p>
      </div>
      <Stamp
        class="absolute top-1/2 right-2 hidden -translate-y-1/2 text-brand/70 lg:inline-grid"
      />
    </div>
  </section>

  <section class="container-site pb-24 md:pb-32" aria-label="Publicações do blog">
    <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3 md:gap-8">
      {destaque && <BlogCard post={destaque} featured />}
      {demais.map((post, i) => <BlogCard post={post} index={i} />)}
    </div>
  </section>
</BaseLayout>
