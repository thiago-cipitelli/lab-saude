---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Stamp from '../components/Stamp.astro';
import Timeline from '../components/Timeline.astro';

const events = (await getCollection('timeline')).sort(
  (a, b) => Number(a.data.ano) - Number(b.data.ano),
);
---

<BaseLayout
  title="Linha do Tempo"
  description="De 1957 até hoje: os marcos, aquisições e lançamentos que fizeram do Laboratório Saúde uma tradição farmacêutica gaúcha."
>
  <section class="container-site pt-16 pb-12 md:pt-24 md:pb-16">
    <div
      class="flex flex-col items-start gap-10 md:flex-row md:items-center md:justify-between"
    >
      <div class="max-w-2xl" data-reveal>
        <p class="eyebrow">Desde 1957</p>
        <h1 class="mt-3 text-5xl sm:text-6xl md:text-7xl">
          Nossa <em class="italic">História</em>
        </h1>
        <p class="mt-6 text-lg text-ink-soft md:text-xl">
          Somos reconhecidos por produtos que moram no coração dos gaúchos e
          que trazem lembranças da família, da infância e tantos outros
          momentos marcantes.
        </p>
      </div>
      <div class="shrink-0" data-reveal style="--reveal-delay: 140ms">
        <Stamp class="text-brand" />
      </div>
    </div>
  </section>

  <section
    class="container-site pb-20 md:pb-28"
    aria-label="Linha do tempo do Laboratório Saúde"
  >
    <Timeline events={events} />
  </section>

  <section class="container-site pb-24">
    <div
      class="rounded-2xl bg-brand px-6 py-14 text-center text-white shadow-card sm:px-12 md:py-16"
      data-reveal
    >
      <p class="text-xs font-bold tracking-[0.22em] uppercase">
        A história continua
      </p>
      <h2 class="mx-auto mt-3 max-w-2xl text-3xl text-white sm:text-4xl">
        Tradição que passa de <em class="italic">geração</em> em geração
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-brand-wash">
        Conheça de perto quem faz o Laboratório Saúde e os produtos que
        marcaram época.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/produtos/"
          class="btn bg-white text-brand hover:-translate-y-px hover:bg-brand-wash"
        >
          Conheça nossos produtos
        </a>
        <a
          href="/quem-somos/"
          class="btn border-white text-white hover:bg-white hover:text-brand"
        >
          Quem somos
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
