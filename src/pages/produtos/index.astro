---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Stamp from '../../components/Stamp.astro';
import { SITE, CATEGORIAS } from '../../lib/site';

const porOrdem = (
  a: CollectionEntry<'produtos'>,
  b: CollectionEntry<'produtos'>,
) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title, 'pt-BR');

const produtos = (await getCollection('produtos')).sort(porOrdem);

const contagemPorCategoria = new Map(
  CATEGORIAS.map((c) => [
    c.slug,
    produtos.filter((p) => p.data.category === c.nome).length,
  ]),
);

const pillBase =
  'inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all duration-200';
const pillAtiva =
  'bg-brand text-white shadow-[0_8px_20px_-6px_rgb(231_0_50/0.45)]';
const pillNeutra =
  'border border-line bg-white text-ink-soft hover:-translate-y-0.5 hover:border-brand/40 hover:text-brand hover:shadow-card';
---

<BaseLayout
  title="Produtos"
  description="Conheça os cosméticos, medicamentos e alimentos do Laboratório Saúde — produtos que moram no coração dos gaúchos desde 1957."
>
  <section class="container-site pt-14 md:pt-20">
    <div class="flex flex-wrap items-end justify-between gap-10">
      <div class="max-w-3xl" data-reveal>
        <p class="eyebrow">Nossos produtos</p>
        <h1 class="mt-3 text-4xl sm:text-5xl md:text-6xl">
          Produtos que moram no <em class="italic">coração</em> dos gaúchos
        </h1>
        <p class="mt-5 max-w-2xl text-lg text-ink-soft">
          Cosméticos, medicamentos isentos de prescrição e alimentos funcionais
          — feitos com qualidade e carinho para todas as gerações, do bebê aos
          avós.
        </p>
      </div>
      <div class="hidden md:block" data-reveal style="--reveal-delay: 120ms">
        <Stamp class="text-brand" />
      </div>
    </div>

    <nav
      aria-label="Filtrar produtos por categoria"
      class="mt-10 flex flex-wrap items-center gap-2.5"
      data-reveal
      style="--reveal-delay: 180ms"
    >
      <a href="/produtos/" aria-current="page" class:list={[pillBase, pillAtiva]}>
        Todos
        <span class="rounded-full bg-white px-2 py-0.5 text-[0.7rem] font-bold tabular-nums text-brand">
          {produtos.length}
        </span>
      </a>
      {
        CATEGORIAS.map((c) => (
          <a href={`/categorias/${c.slug}/`} class:list={[pillBase, pillNeutra]}>
            {c.nome}
            <span class="rounded-full bg-paper-deep px-2 py-0.5 text-[0.7rem] font-bold tabular-nums text-ink-soft">
              {contagemPorCategoria.get(c.slug)}
            </span>
          </a>
        ))
      }
    </nav>
  </section>

  <section class="container-site mt-12 md:mt-16">
    <h2 class="sr-only">Lista de produtos</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {produtos.map((produto, i) => <ProductCard produto={produto} index={i} eager={i < 4} />)}
    </div>
  </section>

  <section class="container-site mt-20 pb-24 md:mt-24">
    <div
      class="relative overflow-hidden rounded-3xl bg-brand px-8 py-12 text-white shadow-card sm:px-12 md:flex md:items-center md:justify-between md:gap-10"
      data-reveal
    >
      <div aria-hidden="true" class="absolute -top-28 -right-20 h-72 w-72 rounded-full bg-white/10"></div>
      <div aria-hidden="true" class="absolute -bottom-32 -left-16 h-64 w-64 rounded-full bg-black/10"></div>
      <div class="relative max-w-xl">
        <h2 class="text-3xl text-white sm:text-4xl">
          Nossos clássicos a um <em class="italic">clique</em>
        </h2>
        <p class="mt-3 text-white">
          Compre os produtos do Laboratório Saúde direto na nossa loja online.
        </p>
      </div>
      <a
        href={SITE.lojaUrl}
        target="_blank"
        rel="noopener"
        class="btn relative mt-8 bg-white text-brand hover:-translate-y-0.5 hover:bg-paper hover:shadow-lg md:mt-0"
      >
        Visitar a loja online
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path
            d="M3 11 11 3m0 0H4.5M11 3v6.5"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
